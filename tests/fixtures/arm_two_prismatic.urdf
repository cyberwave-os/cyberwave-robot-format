<?xml version="1.0"?>
<robot name="arm_only">
  <link name="base"/>
  <link name="link1"/>
  <link name="link2"/>
  <joint name="joint1" type="prismatic">
    <parent link="base"/><child link="link1"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.0" effort="100" velocity="1"/>
  </joint>
  <joint name="joint2" type="prismatic">
    <parent link="base"/><child link="link2"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.0" effort="100" velocity="1"/>
  </joint>
</robot>
